@model CartViewModel

@section Bar
{
  <section class="bg-primary p-3">
    <div class="container">
      <nav>
        <ol class="breadcrumb mb-0">
          <li class="breadcrumb-item">
            <a href="#">Anasayfa</a>
          </li>
          <li class="breadcrumb-item">
            Alışveriş Sepeti
          </li>
        </ol>
      </nav>
    </div>
  </section>
}

<section class="mt-3">
  <div class="container">
    <div class="row py-3">

      @if (Model.CartItems.Count > 0)
      {
        <div class="col-lg-7">
          <ul class="list-group">

            @foreach (var item in Model.CartItems)
            {
              <li class="py-3 mb-2 border-top list-group-item">
                <div class="row align-items-center">
                  <div class="col-7">
                    <div class="d-flex align-items-center">
                      <img src="img/@item.Resim" style="width: 100px;" alt="">
                      <div class="ms-3">
                        <a asp-controller="Urun" asp-action="Details" asp-route-id="@item.UrunId"
                           class="text-decoration-none">
                          <h6 class="mb-0">@item.UrunAdi</h6>
                        </a>
                      </div>
                    </div>
                  </div>
                  <div class="col-2">
                    <input type="number" value="@item.Miktar" class="form-control" min="1">
                  </div>
                  <div class="col-2 text-center">
                    <span class="fw-bold">@item.Fiyat ₺</span>
                  </div>
                  <div class="col-1 text-center">
                    <form method="post" asp-controller="Cart" asp-action="RemoveItem">
                      <input type="hidden" name="urunId" value="@item.UrunId">
                      <input type="hidden" name="miktar" value="1">
                      <button type="submit" class="btn btn-sm btn-danger">
                        <i class="fa-solid fa-trash"></i>
                      </button>
                    </form>
                  </div>
                </div>
              </li>
            }

          </ul>
        </div>

        <div class="col-lg-5">
          <div class=" p-2 card">
            <div class="card-body">
              <h2 class="h5 mb-4">Sipariş Özeti</h2>
              <div class="card mb-2">
                <div class="list-group list-group-flush">
                  <div class="d-flex justify-content-center align-items-center list-group-item">
                    <div class="me-auto">
                      <div>Sipariş Toplamı</div>
                    </div>
                    <span>@Model.AraToplam ₺</span>
                  </div>
                  <div class="d-flex justify-content-center align-items-center list-group-item">
                    <div class="me-auto">
                      <div>Kargo Ücreti</div>
                    </div>
                    <span>Ücretsiz</span>
                  </div>
                  <div class="d-flex justify-content-center align-items-center list-group-item">
                    <div class="me-auto">
                      <div>Vergi (%20)</div>
                    </div>
                    <span>@(Model.AraToplam * 0.2) ₺</span>
                  </div>
                  <div class="d-flex justify-content-center align-items-center list-group-item">
                    <div class="me-auto">
                      <div>Toplam</div>
                    </div>
                    <span>@Model.Toplam ₺</span>
                  </div>
                </div>
              </div>
              <div class="d-grid">
                <a href="#" class="btn btn-primary btn-lg">
                  Siparişi Tamamla
                </a>
              </div>
            </div>
          </div>
        </div>
      }
      else
      {
        <div class="col-lg-12">
          <div class="alert alert-warning">Sepetinizde ürün bulunmamaktadır.</div>
        </div>
      }
    </div>
  </div>
</section>