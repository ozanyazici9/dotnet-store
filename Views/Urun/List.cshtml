@using dotnet_store.Data
@model List<Urun>

@section Bar {
  @await Component.InvokeAsync("Navbar")
}

<section class="mt-3 mb-3">
      <div class="container">
        <h3 class="h4 mb-1 mb-lg-3">Ürün Listesi</h3>

        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-2">
            @foreach (var urun in Model) {
                <div class="col">
                    @await Html.PartialAsync(partialViewName: "Partials/Site/_UrunCard", urun)
                </div>
            }
        </div>
      </div>
</section>