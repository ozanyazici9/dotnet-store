@model AccountChangePasswordModel

@section Bar
{
  <section class="bg-primary p-3">
    <div class="container">
      <nav>
        <ol class="breadcrumb mb-0">
          <li class="breadcrumb-item">
            <a href="#">Anasayfa</a>
          </li>
          <li class="breadcrumb-item">
            Parola İşlemleri
          </li>
        </ol>
      </nav>
    </div>
  </section>
}

<section class="mt-4">
  <div class="container">
    <div class="row">
      <div class="col-md-3">
        @await Html.PartialAsync(partialViewName: "Partials/Site/_AccountEditMenu")
      </div>
      <div class="col-9">

        <div class="card shadow">
          <div class="card-header py-1">
            <h5 class="card-title">Parola Değiştir</h5>
          </div>
          <div class="card-body">
            <form method="post" asp-action="ChangePassword">
              <div asp-validation-summary="All" class="text-danger"></div>
              <div class="row mb-3">
                <label asp-for="CurrentPassword" class="col-sm-2 col-form-label"></label>
                <div class="col-sm-10">
                  <input asp-for="CurrentPassword" class="form-control">
                  <span asp-validation-for="CurrentPassword" class="text-danger"></span>
                </div>
              </div>
              <div class="row mb-3">
                <label asp-for="NewPassword" class="col-sm-2 col-form-label"></label>
                <div class="col-sm-10">
                  <input asp-for="NewPassword" class="form-control">
                  <span asp-validation-for="NewPassword" class="text-danger"></span>
                </div>
              </div>
              <div class="row mb-3">
                <label asp-for="ConfirmNewPassword" class="col-sm-2 col-form-label"></label>
                <div class="col-sm-10">
                  <input asp-for="ConfirmNewPassword" class="form-control">
                  <span asp-validation-for="ConfirmNewPassword" class="text-danger"></span>
                </div>
              </div>
              <div class="row mb-3">
                <div class="col-sm-10 offset-sm-2">
                  <button type="submit" class="btn btn-primary">Kaydet</button>
                </div>
              </div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

@section Scripts {
  @await Html.PartialAsync("_ValidationScriptsPartial")
}