@model SliderEditModel

@{
    Layout = "_AdminLayout";
}

<form method="post" enctype="multipart/form-data">
    <div class="row">
        <div class="col-md-12">
            <div class="card shadow">
                <div class="card-header py-1 d-flex justify-content-between align-items-center">
                    <h5 class="card-title">Slider Düzenle</h5>
                    <a asp-controller="Slider" asp-action="Index" class="btn btn-sm btn-primary">
                        <i class="fa-solid fa-list"></i>
                    </a>
                </div>
                <div class="card-body">
                    <input type="hidden" asp-for="Id">
                    <div class="row mb-3">
                        <label asp-for="ResimAdi" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10"  style="height: 400px; overflow: hidden;">
                            <img src="~/img/@Model.ResimAdi" class="img-thumbnail border-0 w-100 h-100" alt="">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Baslik" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Baslik" class="form-control">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Aciklama" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <textarea asp-for="Aciklama" class="form-control"></textarea>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="ResimDosyasi" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="ResimDosyasi" class="form-control">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Index" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <select asp-for="Index" class="form-select" asp-items="ViewBag.Indexes">
                                <option value="" selected>Seçiniz</option>
                            </select>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Aktif" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Aktif" class="form-check-input">
                        </div>
                    </div>
                    <div class="row mb-3">
                        <div class="col-sm-10 offset-sm-2">
                            <button type="submit" class="btn btn-primary">Kaydet</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</form>

@section Scripts {@await Html.PartialAsync("_ValidationScriptsPartial")}