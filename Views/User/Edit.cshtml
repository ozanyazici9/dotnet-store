@using Microsoft.EntityFrameworkCore.Metadata.Internal
@model UserEditModel

@{
    Layout = "_AdminLayout";
}

<div class="row">
    <div class="col">
        <div class="card shadow">
            <div class="card-header py-1 d-flex justify-content-between align-items-center">
                <h5 class="card-title">Kullanıcı Düzenle</h5>
                <a asp-action="Index" class="btn btn-sm btn-primary">
                    <i class="fa-solid fa-list"></i>
                </a>
            </div>
            <div class="card-body">
                <form method="post" asp-action="Edit">
                    <input type="hidden" asp-for="Id">
                    <div asp-validation-summary="All" class="text-danger"></div>

                    @*Kişisel Bilgiler*@
                    <div class="card shadow">
                        <div class="card-header py-1 d-flex justify-content-between align-items-center">
                            <h5 class="card-title">Kişisel Bilgi Güncelle</h5>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                        <label asp-for="AdSoyad" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="AdSoyad" class="form-control">
                            <span asp-validation-for="AdSoyad" class="text-danger"></span>
                        </div>
                    </div>
                    <div class="row mb-3">
                        <label asp-for="Email" class="col-sm-2 col-form-label"></label>
                        <div class="col-sm-10">
                            <input asp-for="Email" class="form-control">
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                    </div>
                        </div>
                    </div>

                    @*Parola*@
                    <div class="card shadow my-4">
                        <div class="card-header py-1 d-flex justify-content-between align-items-center">
                            <h5 class="card-title">Parola Güncelle</h5>
                        </div>
                        <div class="card-body">
                            <div class="row mb-3">
                                <label asp-for="Password" class="col-sm-2 col-form-label"></label>
                                <div class="col-sm-10">
                                    <input asp-for="Password" class="form-control">
                                    <span asp-validation-for="Password" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="row mb-3">
                                <label asp-for="PasswordConfirm" class="col-sm-2 col-form-label"></label>
                                <div class="col-sm-10">
                                    <input asp-for="PasswordConfirm" class="form-control">
                                    <span asp-validation-for="PasswordConfirm" class="text-danger"></span>
                                </div>
                            </div>
                        </div>
                    </div>

                    @*Roller*@
                    <div class="card shadow">
                        <div class="card-header py-1 d-flex justify-content-between align-items-center">
                            <h5 class="card-title">Roller</h5>
                        </div>
                        <div class="card-body">

                            @foreach (var role in Model.AllRoles)
                            {
                                <div class="row mb-3">
                                    <div class="form-check mx-3">
                                        <input type="checkbox" name="SelectedRoles" id="@role" value="@role" class="form-check-input"
                                            checked="@(Model.UserRoles.Contains(role) ? "checked" : null)" />
                                        <label for="@role" asp-for="SelectedRoles" class="form-check-label">@role</label>
                                    </div>
                                </div>
                                <span asp-validation-for="SelectedRoles" class="text-danger"></span>
                            }

                        </div>
                    </div>
                    <div class="row my-3">
                        <div class="col-sm-10 ">
                            <button type="submit" class="btn btn-primary">Kaydet</button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
}